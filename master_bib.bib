  shorttitle = {Comparative {{Analyses}} of {{Public Attitudes Toward Immigrants}} and {{Immigration Using Multinational Survey Data}}},
  author = {Ceobanu, Alin M. and Escandell, Xavier},
  year = 2010,
  journal = {Annual Review of Sociology},
