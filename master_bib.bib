@article{tingleyPublicFinanceImmigration2013,
  title = {Public {{Finance}} and {{Immigration Preferences}}: {{A Lost Connection}}?},
  shorttitle = {Public {{Finance}} and {{Immigration Preferences}}},
  author = {Tingley, Dustin},
  year = 2013,
  month = jan,
  journal = {Polity},
  volume = {45},
  number = {1},
  pages = {4--33},
  publisher = {The University of Chicago Press},
  issn = {0032-3497},
  doi = {10.1057/pol.2012.30},
  urldate = {2026-03-14},
  abstract = {Do material interests shape a person's views on immigration? If so, how? In a widely cited study, Gordon Hanson, Kenneth Scheve, and Matthew J. Slaughter contend that the public finance environment of each U.S. state affects the way an individual's skill level influences her or his support for immigration. Jens Hainmueller and Michael J. Hiscox disagree with the public finance argument and have maintained that nonmaterial factors better explain immigration preferences. This article revisits the debate about material interests with a range of new data and finds little support for the public finance hypothesis. The study also offers some explanations for these less-supportive results, provides directions for future work, and reflects on how empirical research on nonmaterialist explanations can be enhanced methodologically and conceptually.}
}

